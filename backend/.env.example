# Copy this file to .env and fill in real values. Never commit .env.

# --- Database ---
# Quick local start (no MySQL install needed):
#   DATABASE_URL=sqlite:///insightiq.db
# Production / spec-compliant (requires a running MySQL server):
#   DATABASE_URL=mysql+pymysql://insightiq_user:password@localhost:3306/insightiq
DATABASE_URL=sqlite:///insightiq.db

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-64-char-hex-string
FLASK_SECRET_KEY=change-this-too

# --- App ---
FLASK_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
MAX_UPLOAD_MB=25
UPLOAD_FOLDER=uploads
JWT_ACCESS_TOKEN_EXPIRES_MIN=60

# --- Ask INSIGHT IQ (Phase 8 AI assistant) ---
# Get a key from https://console.anthropic.com/settings/keys
# Leave blank to keep the rest of the app working; the /ask endpoint will
# just respond with a setup message instead of an answer until this is set.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
